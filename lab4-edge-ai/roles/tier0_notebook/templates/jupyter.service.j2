[Unit]
Description=DIGITAfrica Tier-0 JupyterLab
After=network.target

[Service]
Type=simple
User={{ tier0_notebook_user }}
WorkingDirectory={{ tier0_notebook_dir }}
Environment=PATH=/opt/digitafrica/tier0-venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/opt/digitafrica/tier0-venv/bin/jupyter lab \
  --ip=0.0.0.0 --port={{ tier0_notebook_port }} --no-browser \
  --ServerApp.password="{{ tier0_notebook_password_hash }}" \
  --ServerApp.token="" \
  --ServerApp.allow_remote_access=True
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
