apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: tier0-notebooks-pvc
  namespace: {{ digitafrica_namespace }}
spec:
  accessModes: ["ReadWriteOnce"]
  resources:
    requests:
      storage: {{ tier0_notebooks_storage | default("8Gi") }}

---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: tier0-jupyter
  namespace: {{ digitafrica_namespace }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: tier0-jupyter
  template:
    metadata:
      labels:
        app: tier0-jupyter
    spec:
      containers:
        - name: jupyter
          image: {{ tier0_jupyter_image | default("jupyter/minimal-notebook:python-3.11") }}
          ports:
            - containerPort: 8888
          command: ["/bin/bash","-lc"]
          args:
            - |
              # Optional: install deps if requirements.txt exists in the mounted volume
              if [ -f /home/jovyan/digitafrica/requirements.txt ]; then
                pip install --no-cache-dir -r /home/jovyan/digitafrica/requirements.txt || true
              fi
              start-notebook.py \
                --ServerApp.ip=0.0.0.0 \
                --ServerApp.port=8888 \
                --ServerApp.token='' \
                --ServerApp.password='{{ tier0_notebook_password_hash }}' \
                --ServerApp.allow_remote_access=True
          volumeMounts:
            - name: digitafrica
              mountPath: /home/jovyan/digitafrica
      volumes:
        - name: digitafrica
          persistentVolumeClaim:
            claimName: tier0-notebooks-pvc

---
apiVersion: v1
kind: Service
metadata:
  name: tier0-jupyter
  namespace: {{ digitafrica_namespace }}
spec:
  selector:
    app: tier0-jupyter
  type: NodePort
  externalTrafficPolicy: Local
  ports:
    - name: http
      port: 8888
      targetPort: 8888
      nodePort: {{ tier0_jupyter_nodeport | default(30888) }}
